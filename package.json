{
  "name": "heyphil-app",
  "version": "1.0.0",
  "description": "HeyPhil - Project management and productivity tools",
  "type": "module",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "build": "cd client && npm install && npm run build",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "setup": "npm install && cd client && npm install",
    "migrate": "node server/migrate-from-sheets.js",
    "db:init": "node server/init-db.js",
    "railway:build": "npm install && cd client && npm install && npm run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "elkjs": "^0.11.0",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "googleapis": "^131.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
